%%{init: {'flowchart': {'curve': 'linear'}}}%%
graph TD;
	__start__([<p>__start__</p>]):::first
	extract(extract)
	validate(validate)
	retry(retry)
	finalize(finalize)
	temporalAdvice(temporalAdvice)
	__end__([<p>__end__</p>]):::last
	__start__ --> extract;
	extract --> validate;
	retry --> validate;
	temporalAdvice --> __end__;
	validate -.-> finalize;
	validate -.-> retry;
	finalize -. &nbsp;temporal&nbsp; .-> temporalAdvice;
	finalize -. &nbsp;end&nbsp; .-> __end__;
	classDef default fill:#f2f0ff,line-height:1.2;
	classDef first fill-opacity:0;
	classDef last fill:#bfb6fc;
